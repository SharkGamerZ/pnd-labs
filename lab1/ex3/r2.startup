ip addr flush eth0
ip addr flush eth1

# Lan2
ip addr add 172.16.2.254/24 dev eth1
ip link set eth1 up

# Internal
ip addr add 172.16.254.2/24 dev eth0
ip link set eth0 up

ip route add default via 172.16.254.254
ip route add 172.16.1.0/24 via 172.16.254.1

echo "nameserver 151.100.4.2" >> /etc/resolv.conf
echo "nameserver 151.100.4.13" >> /etc/resolv.conf


